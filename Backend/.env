# Database connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root          # or your MySQL user name
DB_PASSWORD=          # leave empty if you set no password
DB_NAME=iftiin         # the database name we will create

# JWT secret (any string you like)
JWT_SECRET=dev_secret

# Front‑end URL (used for CORS)
CLIENT_ORIGIN=http://localhost:5173
